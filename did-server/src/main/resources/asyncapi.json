      "com.managination.numa.didserver.dto.websocket.CredentialMessage": {
        "title": "CredentialMessage",
        "type": "object",
        "properties": {
          "credential": {
            "type": "string",
            "description": "The signed JWT verifiable credential"
          },
          "format": {
            "type": "string",
            "description": "Credential format (e.g., jwt_vc_json)"
          },
          "sessionId": {
            "type": "string",
            "description": "The session this message belongs to"
          },
          "timestamp": {
            "type": "string",
            "description": "ISO-8601 timestamp of when the message was created"
          },
          "type": {
            "type": "string",
            "description": "Message type identifier",
            "examples": [
              "credential"
            ]
          }
        },
        "description": "Sent by the issuer to the server, which relays it to the holder. Contains the signed JWT verifiable credential.",
        "examples": [
          {
            "credential": "string",
            "format": "jwt_vc_json",
            "sessionId": "string",
            "timestamp": "string",
            "type": "credential"
          }
        ],
        "required": [
          "credential",
          "sessionId",
          "type"
        ]
      },
      "com.managination.numa.didserver.dto.websocket.CredentialReceivedMessage": {
        "title": "CredentialReceivedMessage",
        "type": "object",
        "properties": {
          "sessionId": {
            "type": "string",
            "description": "The session this message belongs to"
          },
          "timestamp": {
            "type": "string",
            "description": "ISO-8601 timestamp of when the message was created"
          },
          "type": {
            "type": "string",
            "description": "Message type identifier",
            "examples": [
              "credential_received"
            ]
          }
        },
        "description": "Sent by the server to the issuer to confirm the holder has received the credential.",
        "examples": [
          {
            "sessionId": "string",
            "timestamp": "string",
            "type": "credential_received"
          }
        ],
        "required": [
          "sessionId",
          "type"
        ]
      },
      "com.managination.numa.didserver.dto.websocket.ErrorMessage": {
        "title": "ErrorMessage",
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "description": "Error code for programmatic handling",
            "enum": [
              "INVALID_MESSAGE",
              "UNAUTHORIZED",
              "SESSION_NOT_FOUND",
              "SESSION_EXPIRED",
              "DUPLICATE_JOIN",
              "ROLE_MISMATCH",
              "INVALID_DID",
              "INVALID_CREDENTIAL",
              "INTERNAL_ERROR",
              "MESSAGE_TOO_LARGE",
              "INVALID_FORMAT"
            ]
          },
          "message": {
            "type": "string",
            "description": "Human-readable error description"
          },
          "sessionId": {
            "type": "string",
            "description": "The session this message belongs to"
          },
          "timestamp": {
            "type": "string",
            "description": "ISO-8601 timestamp of when the message was created"
          },
          "type": {
            "type": "string",
            "description": "Message type identifier",
            "examples": [
              "error"
            ]
          }
        },
        "description": "Sent by the server to either party when an error occurs during the session.",
        "examples": [
          {
            "code": "INVALID_MESSAGE",
            "message": "string",
            "sessionId": "string",
            "timestamp": "string",
            "type": "error"
          }
        ],
        "required": [
          "code",
          "message",
          "sessionId",
          "type"
        ]
      },
